<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="{{ .Description }}" />
  <title>{{ .Title }}{{ if .ServerMode }} · Tracked Mode{{ else }} · Static Mode{{ end }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    /* ── Design Tokens ──────────────────────────────────────────────── */
    :root {
      --bg:          #0d0f1a;
      --surface:     #141726;
      --surface-2:   #1d2035;
      --surface-3:   #252944;
      --border:      #2e3354;
      --accent:      #7c6af0;
      --accent-glow: rgba(124,106,240,0.22);
      --accent-2:    #5de4c7;
      --correct:     #22d97a;
      --correct-bg:  rgba(34,217,122,0.1);
      --wrong:       #f05d7c;
      --wrong-bg:    rgba(240,93,124,0.1);
      --text:        #e8eaf6;
      --text-muted:  #8991b4;
      --text-dim:    #5a6080;
      --radius:      12px;
      --radius-sm:   8px;
      --sidebar-w:   260px;
      --topbar-h:    52px;
      --pb-h:        3px;
      --transition:  0.18s ease;
      --content-max: 720px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      height: 100vh;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    /* ── Topbar ──────────────────────────────────────────────────────── */
    .topbar {
      height: var(--topbar-h);
      flex-shrink: 0;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      display: grid;
      grid-template-columns: var(--sidebar-w) 1fr auto;
      align-items: center;
      padding: 0 1rem;
      z-index: 100;
    }
    .topbar-brand {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
    }
    .topbar-brand .icon { color: var(--accent); font-size: 1.1rem; flex-shrink: 0; }
    .topbar-brand-name {
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .topbar-center {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1rem;
    }
    .q-counter {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--text-muted);
      white-space: nowrap;
    }
    .q-counter span { color: var(--accent-2); }
    .topbar-end {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      justify-content: flex-end;
    }
    .score-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      background: var(--surface-3);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 0.25rem 0.7rem;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-muted);
      white-space: nowrap;
    }
    .score-pill .val { color: var(--accent-2); }
    .mode-pill {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 0.25rem 0.75rem;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      white-space: nowrap;
      border: 1px solid var(--border);
    }
    .mode-pill.tracked {
      color: var(--correct);
      background: var(--correct-bg);
      border-color: rgba(34,217,122,0.45);
    }
    .mode-pill.static {
      color: #ffcc66;
      background: rgba(255,204,102,0.12);
      border-color: rgba(255,204,102,0.38);
    }

    /* ── Progress Bar ───────────────────────────────────────────────── */
    .progress-wrap {
      height: var(--pb-h);
      flex-shrink: 0;
      background: var(--surface-3);
    }
    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--accent-2));
      width: 0%;
      transition: width 0.45s ease;
      border-radius: 0 2px 2px 0;
    }
    .mode-banner {
      flex-shrink: 0;
      padding: 0.85rem 1rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 1rem;
      align-items: baseline;
    }
    .mode-banner.tracked {
      background: linear-gradient(90deg, rgba(34,217,122,0.14), rgba(93,228,199,0.08));
    }
    .mode-banner.static {
      background: linear-gradient(90deg, rgba(255,204,102,0.14), rgba(255,204,102,0.06));
    }
    .mode-banner-title {
      font-size: 0.74rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .mode-banner.tracked .mode-banner-title { color: var(--correct); }
    .mode-banner.static .mode-banner-title { color: #ffcc66; }
    .mode-banner-text {
      font-size: 0.84rem;
      color: var(--text-muted);
      max-width: 980px;
    }

    /* ── Body Layout ─────────────────────────────────────────────────── */
    .body-layout {
      display: flex;
      flex: 1;
      min-height: 0; /* critical for flex overflow */
    }

    /* ── Sidebar ─────────────────────────────────────────────────────── */
    .sidebar {
      width: var(--sidebar-w);
      flex-shrink: 0;
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .sidebar-header {
      padding: 0.75rem 0.85rem 0.6rem;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .sidebar-label {
      font-size: 0.65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-dim);
    }
    .sidebar-scroll {
      flex: 1;
      overflow-y: auto;
      padding: 0.4rem;
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
    }
    .sidebar-scroll::-webkit-scrollbar { width: 4px; }
    .sidebar-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      padding: 0.5rem 0.6rem;
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition: background var(--transition), color var(--transition);
      color: var(--text-muted);
      font-size: 0.8rem;
      border: 1px solid transparent;
      margin-bottom: 2px;
      user-select: none;
    }
    .nav-item:hover { background: var(--surface-2); color: var(--text); }
    .nav-item.active {
      background: var(--surface-3);
      border-color: var(--border);
      color: var(--text);
    }
    .nav-item.correct { color: var(--correct); }
    .nav-item.wrong   { color: var(--wrong); }
    .nav-num {
      flex-shrink: 0;
      width: 20px; height: 20px;
      border-radius: 50%;
      border: 1.5px solid currentColor;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.65rem;
      font-weight: 700;
    }
    .nav-text { flex: 1; line-height: 1.25; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .nav-badge {
      font-size: 0.58rem;
      padding: 0.1rem 0.35rem;
      border-radius: 10px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      color: var(--text-dim);
      flex-shrink: 0;
      white-space: nowrap;
    }
    .nav-item.correct .nav-badge { background: var(--correct-bg); border-color: var(--correct); color: var(--correct); }
    .nav-item.wrong   .nav-badge { background: var(--wrong-bg);   border-color: var(--wrong);   color: var(--wrong);   }

    /* ── Main stage ──────────────────────────────────────────────────── */
    .stage {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── Question Page ───────────────────────────────────────────────── */
    .q-page {
      display: none;
      flex-direction: column;
      flex: 1;
      min-height: 0;
      padding: 1.5rem 2rem 1rem;
      overflow: hidden;
    }
    .q-page.active { display: flex; }

    /* ── Question meta row ───────────────────────────────────────────── */
    .q-meta {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 0.85rem;
      flex-shrink: 0;
    }
    .q-type-pill {
      font-size: 0.65rem;
      font-weight: 700;
      padding: 0.2rem 0.55rem;
      border-radius: 20px;
      background: var(--accent-glow);
      border: 1px solid var(--accent);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.07em;
    }
    .q-title-text {
      font-size: 0.78rem;
      color: var(--text-dim);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .btn-hint-inline {
      margin-left: auto;
      font-size: 0.72rem;
      padding: 0.22rem 0.65rem;
      border-radius: 20px;
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text-muted);
      cursor: pointer;
      transition: border-color var(--transition), color var(--transition);
      flex-shrink: 0;
    }
    .btn-hint-inline:hover { border-color: var(--accent); color: var(--accent); }

    .tag-row { display: flex; gap: 0.35rem; flex-wrap: wrap; margin-bottom: 0.65rem; flex-shrink: 0; }
    .tag {
      font-size: 0.63rem;
      padding: 0.1rem 0.45rem;
      border-radius: 10px;
      background: var(--surface-3);
      color: var(--text-dim);
      border: 1px solid var(--border);
    }

    /* ── Hint Box ────────────────────────────────────────────────────── */
    .hint-box {
      background: rgba(124,106,240,0.07);
      border: 1px dashed var(--accent);
      border-radius: var(--radius-sm);
      padding: 0.55rem 0.85rem;
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-bottom: 0.65rem;
      display: none;
      flex-shrink: 0;
    }
    .hint-box.visible { display: block; }
    .hint-label { font-size: 0.7rem; font-weight: 700; color: var(--accent); margin-bottom: 0.2rem; }

    /* ── Prompt ──────────────────────────────────────────────────────── */
    .q-prompt {
      font-size: 1.05rem;
      font-weight: 500;
      line-height: 1.65;
      color: var(--text);
      margin-bottom: 1rem;
      flex-shrink: 0;
      max-height: 34vh;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
      padding-right: 4px;
    }
    .q-prompt p { margin-bottom: 0.4rem; }
    .q-prompt p:last-child { margin-bottom: 0; }
    .q-prompt::-webkit-scrollbar { width: 4px; }
    .q-prompt::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
    .q-prompt code {
      font-size: 0.875em;
      background: var(--surface-3);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.1em 0.4em;
    }

    /* ── Answers area (scrollable if overflows) ───────────────────────── */
    .answers-area {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent;
      padding-right: 4px;
      margin-bottom: 0.75rem;
    }
    .answers-area::-webkit-scrollbar { width: 4px; }
    .answers-area::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    /* ── Choice items ────────────────────────────────────────────────── */
    .choice-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .choice-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.7rem 0.95rem;
      border-radius: var(--radius-sm);
      border: 1.5px solid var(--border);
      background: var(--surface-2);
      cursor: pointer;
      transition: border-color var(--transition), background var(--transition), transform var(--transition);
      user-select: none;
    }
    .choice-item:hover { border-color: var(--accent); background: var(--surface-3); transform: translateX(2px); }
    .choice-item.selected { border-color: var(--accent); background: rgba(124,106,240,0.1); }
    .choice-item.correct-reveal { border-color: var(--correct) !important; background: var(--correct-bg) !important; }
    .choice-item.wrong-reveal   { border-color: var(--wrong)   !important; background: var(--wrong-bg)   !important; }
    .choice-item.user-picked { box-shadow: inset 0 0 0 1px rgba(124,106,240,0.8); }
    .choice-item.missed-correct { border-style: dashed; }
    .choice-item.disabled { cursor: default; pointer-events: none; }
    .choice-marker {
      width: 18px; height: 18px;
      border-radius: 50%;
      border: 2px solid var(--border);
      flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      transition: border-color var(--transition), background var(--transition);
      font-size: 0.6rem;
    }
    .choice-marker.checkbox { border-radius: 4px; }
    .choice-item.selected .choice-marker      { border-color: var(--accent);  background: var(--accent);  }
    .choice-item.correct-reveal .choice-marker { border-color: var(--correct); background: var(--correct); }
    .choice-item.wrong-reveal   .choice-marker { border-color: var(--wrong);   background: var(--wrong);   }
    .choice-check { color: #fff; font-size: 0.65rem; display: none; }
    .choice-item.selected .choice-check,
    .choice-item.correct-reveal .choice-check,
    .choice-item.wrong-reveal   .choice-check { display: block; }
    .choice-label { flex: 1; font-size: 0.875rem; line-height: 1.4; }
    .choice-state {
      flex-shrink: 0;
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 0.14rem 0.48rem;
      color: var(--text-dim);
      background: var(--surface);
    }
    .choice-state.user { color: var(--accent); border-color: var(--accent); background: rgba(124,106,240,0.12); }
    .choice-state.correct { color: var(--correct); border-color: var(--correct); background: var(--correct-bg); }
    .choice-state.wrong { color: var(--wrong); border-color: var(--wrong); background: var(--wrong-bg); }

    /* ── Multi-True-False ────────────────────────────────────────────── */
    .mtf-list { display: flex; flex-direction: column; gap: 0.45rem; }
    .mtf-row {
      display: flex;
      align-items: center;
      gap: 0.85rem;
      padding: 0.6rem 0.9rem;
      border-radius: var(--radius-sm);
      border: 1.5px solid var(--border);
      background: var(--surface-2);
    }
    .mtf-label { flex: 1; font-size: 0.875rem; line-height: 1.35; }
    .mtf-toggle-group { display: flex; gap: 0.35rem; flex-shrink: 0; }
    .mtf-btn {
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      border: 1.5px solid var(--border);
      background: transparent;
      color: var(--text-muted);
      font-size: 0.76rem;
      font-weight: 700;
      cursor: pointer;
      transition: border-color var(--transition), color var(--transition), background var(--transition);
    }
    .mtf-btn:hover { border-color: var(--accent); color: var(--accent); }
    .mtf-btn.selected-t { border-color: var(--correct); color: var(--correct); background: var(--correct-bg); }
    .mtf-btn.selected-f { border-color: var(--wrong);   color: var(--wrong);   background: var(--wrong-bg);   }
    .mtf-btn.correct-reveal { border-color: var(--correct) !important; color: var(--correct) !important; background: var(--correct-bg) !important; }
    .mtf-btn.wrong-reveal   { border-color: var(--wrong)   !important; color: var(--wrong)   !important; background: var(--wrong-bg)   !important; }
    .mtf-btn.user-picked { box-shadow: inset 0 0 0 1px rgba(124,106,240,0.85); }
    .mtf-row.disabled .mtf-btn { cursor: default; pointer-events: none; }
    .mtf-state {
      margin-top: 0.45rem;
      font-size: 0.72rem;
      color: var(--text-muted);
    }
    .mtf-state .good { color: var(--correct); font-weight: 700; }
    .mtf-state .bad { color: var(--wrong); font-weight: 700; }

    /* ── Short Answer ────────────────────────────────────────────────── */
    .short-answer-input {
      width: 100%;
      background: var(--surface-2);
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 0.65rem 0.9rem;
      font-family: inherit;
      font-size: 0.875rem;
      color: var(--text);
      outline: none;
      resize: vertical;
      min-height: 72px;
      transition: border-color var(--transition);
    }
    .short-answer-input:focus  { border-color: var(--accent); }
    .short-answer-input:disabled { opacity: 0.65; cursor: default; }

    /* ── Ordering ────────────────────────────────────────────────────── */
    .ordering-list { display: flex; flex-direction: column; gap: 0.45rem; list-style: none; }
    .ordering-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.65rem 0.9rem;
      border-radius: var(--radius-sm);
      border: 1.5px solid var(--border);
      background: var(--surface-2);
      cursor: grab;
      user-select: none;
      transition: border-color var(--transition), background var(--transition), box-shadow var(--transition);
    }
    .ordering-item:hover { border-color: var(--accent); background: var(--surface-3); }
    .ordering-item.dragging  { opacity: 0.45; cursor: grabbing; border-color: var(--accent); }
    .ordering-item.drag-over { border-color: var(--accent-2); box-shadow: 0 0 0 2px var(--accent-2); }
    .ordering-item.correct-reveal { border-color: var(--correct); background: var(--correct-bg); }
    .ordering-item.wrong-reveal   { border-color: var(--wrong);   background: var(--wrong-bg); }
    .ordering-item.disabled { cursor: default; pointer-events: none; }
    .drag-handle { color: var(--text-dim); flex-shrink: 0; font-size: 0.9rem; }
    .ordering-rank {
      width: 22px; height: 22px;
      border-radius: 50%;
      border: 1.5px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.7rem; font-weight: 700;
      color: var(--text-muted);
      flex-shrink: 0;
    }
    .ordering-item-label { flex: 1; font-size: 0.875rem; }
    .ordering-state {
      flex-shrink: 0;
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 0.15rem 0.48rem;
      color: var(--text-dim);
      background: var(--surface);
    }
    .ordering-state.correct { color: var(--correct); border-color: var(--correct); background: var(--correct-bg); }
    .ordering-state.wrong { color: var(--wrong); border-color: var(--wrong); background: var(--wrong-bg); }

    /* ── Feedback ────────────────────────────────────────────────────── */
    .feedback {
      display: none;
      border-radius: var(--radius-sm);
      padding: 0.7rem 0.9rem;
      font-size: 0.82rem;
      margin-top: 0.65rem;
      flex-shrink: 0;
      animation: fadeSlideIn 0.25s ease;
    }
    .feedback.visible { display: block; }
    .feedback.correct { background: var(--correct-bg); border: 1px solid var(--correct); color: var(--correct); }
    .feedback.wrong   { background: var(--wrong-bg);   border: 1px solid var(--wrong);   color: var(--wrong);   }
    .feedback-title { font-weight: 700; margin-bottom: 0.3rem; }
    .feedback-explain { color: var(--text); margin-top: 0.5rem; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 0.45rem; font-size: 0.82rem; }
    .feedback-explain p { margin-bottom: 0.3rem; }
    .feedback-explain p:last-child { margin-bottom: 0; }

    .answer-summary {
      margin-top: 0.55rem;
      padding-top: 0.55rem;
      border-top: 1px solid rgba(255,255,255,0.08);
      display: grid;
      gap: 0.5rem;
    }
    .answer-summary-row {
      display: grid;
      grid-template-columns: 132px 1fr;
      align-items: flex-start;
      gap: 0.65rem;
      font-size: 0.8rem;
      line-height: 1.45;
      color: var(--text);
    }
    .answer-summary-label {
      color: var(--text-muted);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      font-size: 0.68rem;
      padding-top: 0.14rem;
    }
    .answer-summary-value {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 0.42rem;
      align-items: center;
    }
    .answer-chip {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface-2);
      padding: 0.18rem 0.52rem;
      font-size: 0.73rem;
      color: var(--text);
      max-width: 100%;
      word-break: break-word;
    }
    .answer-chip.correct { border-color: var(--correct); background: var(--correct-bg); color: var(--correct); }
    .answer-chip.wrong { border-color: var(--wrong); background: var(--wrong-bg); color: var(--wrong); }

    /* ── Action bar ──────────────────────────────────────────────────── */
    .action-bar {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      flex-shrink: 0;
      padding-top: 0.75rem;
      border-top: 1px solid var(--border);
    }
    .btn-nav {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.45rem 0.9rem;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text-muted);
      font-family: inherit;
      font-size: 0.8rem;
      cursor: pointer;
      transition: border-color var(--transition), color var(--transition), background var(--transition);
    }
    .btn-nav:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); background: var(--accent-glow); }
    .btn-nav:disabled { opacity: 0.3; cursor: default; }
    .btn-submit {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.45rem 1.2rem;
      border-radius: var(--radius-sm);
      border: none;
      background: var(--accent);
      color: #fff;
      font-family: inherit;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity var(--transition), transform var(--transition), box-shadow var(--transition);
      box-shadow: 0 3px 14px var(--accent-glow);
    }
    .btn-submit:hover:not(:disabled) { opacity: 0.88; transform: translateY(-1px); }
    .btn-submit:disabled { opacity: 0.35; cursor: default; transform: none; }
    .spacer { flex: 1; }

    /* ── Summary page ────────────────────────────────────────────────── */
    .summary-page {
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      flex: 1;
      padding: 2rem;
      text-align: center;
    }
    .summary-page.active { display: flex; }
    .summary-icon { font-size: 3rem; margin-bottom: 0.75rem; }
    .summary-title { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.25rem; }
    .big-score {
      font-size: 4.5rem;
      font-weight: 800;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1;
      margin: 0.5rem 0;
    }
    .summary-label { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; }
    .summary-mode-note {
      margin-bottom: 1.25rem;
      max-width: 700px;
      font-size: 0.84rem;
      line-height: 1.5;
      padding: 0.7rem 0.9rem;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border);
      color: var(--text-muted);
    }
    .summary-mode-note.tracked {
      background: rgba(34,217,122,0.08);
      border-color: rgba(34,217,122,0.35);
    }
    .summary-mode-note.static {
      background: rgba(255,204,102,0.08);
      border-color: rgba(255,204,102,0.28);
    }
    .summary-stats { display: flex; gap: 2.5rem; justify-content: center; flex-wrap: wrap; }
    .stat { text-align: center; }
    .stat-val { font-size: 1.6rem; font-weight: 700; }
    .stat-val.c  { color: var(--correct); }
    .stat-val.w  { color: var(--wrong); }
    .stat-val.sk { color: var(--text-muted); }
    .stat-lbl { font-size: 0.75rem; color: var(--text-dim); margin-top: 0.15rem; }
    .btn-restart {
      margin-top: 1.75rem;
      padding: 0.55rem 1.5rem;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border);
      background: transparent;
      color: var(--text-muted);
      font-family: inherit;
      font-size: 0.85rem;
      cursor: pointer;
      transition: border-color var(--transition), color var(--transition);
    }
    .btn-restart:hover { border-color: var(--accent); color: var(--accent); }

    /* ── Misc ────────────────────────────────────────────────────────── */
    @keyframes fadeSlideIn {
      from { opacity: 0; transform: translateY(-4px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Responsive ──────────────────────────────────────────────────── */
    @media (max-width: 640px) {
      :root { --sidebar-w: 0px; }
      .sidebar { display: none; }
      .q-page { padding: 1rem; }
      .q-prompt { max-height: 30vh; }
      .topbar { grid-template-columns: 1fr auto; }
      .topbar-brand { display: none; }
      .answer-summary-row { grid-template-columns: 1fr; gap: 0.25rem; }
    }
  </style>
</head>
<body>

  <!-- ── Topbar ─────────────────────────────────────────────────────── -->
  <header class="topbar">
    <div class="topbar-brand">
      <span class="icon">📚</span>
      <span class="topbar-brand-name">{{ .Title }}</span>
    </div>
    <div class="topbar-center">
      <span class="q-counter">Question <span id="cur-q" class="val">1</span> of <span>{{ .TotalCount }}</span></span>
    </div>
    <div class="topbar-end">
      <div class="mode-pill {{ if .ServerMode }}tracked{{ else }}static{{ end }}">{{ if .ServerMode }}Tracked Mode{{ else }}Static Mode{{ end }}</div>
      <div class="score-pill">✓ <span class="val" id="score-correct">0</span> &nbsp;✗ <span class="val" id="score-wrong">0</span></div>
    </div>
  </header>

  <!-- ── Progress Bar ───────────────────────────────────────────────── -->
  <div class="progress-wrap">
    <div class="progress-fill" id="progress-fill"></div>
  </div>

  <section class="mode-banner {{ if .ServerMode }}tracked{{ else }}static{{ end }}" aria-label="Quiz mode status">
    <div class="mode-banner-title">{{ if .ServerMode }}Tracked session active{{ else }}Static HTML only{{ end }}</div>
    <div class="mode-banner-text">
      {{ if .ServerMode }}This quiz is running in tracking mode. Your submitted answers, time spent, and final score are being saved under ~/.sfq/sessions/.{{ else }}This quiz is a static HTML export. sfq is not saving your answers, timing, or final score anywhere. Use sfq track &lt;file.sfq&gt; when you want a persisted session history under ~/.sfq/sessions/.{{ end }}
    </div>
  </section>

  <!-- ── Body Layout ───────────────────────────────────────────────── -->
  <div class="body-layout">

    <!-- Sidebar -->
    <nav class="sidebar" aria-label="Questions">
      <div class="sidebar-header">
        <div class="sidebar-label">All Questions</div>
      </div>
      <div class="sidebar-scroll">
        {{ range .Questions }}
        <div class="nav-item" id="nav-{{ .DOMID }}" onclick="goTo({{ .Index }} - 1)" title="{{ .Title }}">
          <span class="nav-num">{{ .Index }}</span>
          <span class="nav-text">{{ .Title }}</span>
          <span class="nav-badge" id="nav-badge-{{ .DOMID }}">{{ .TypeLabel }}</span>
        </div>
        {{ end }}
        <div class="nav-item" id="nav-summary" onclick="goToSummary()" title="Score Summary">
          <span class="nav-num">🏁</span>
          <span class="nav-text">Summary</span>
        </div>
        {{ if .ServerMode }}
        <div id="sidebar-finish-wrap" style="padding: 0.5rem 0.4rem 0;">
          <button id="sidebar-finish-btn" onclick="sidebarFinish()"
            style="width:100%; display:flex; align-items:center; gap:0.55rem; padding:0.5rem 0.6rem;
                   border-radius:var(--radius-sm); border:1px solid var(--accent);
                   background:var(--accent-glow); color:var(--accent); font-family:inherit;
                   font-size:0.8rem; font-weight:600; cursor:pointer; transition:background var(--transition);">
            ✓ Finish Session
          </button>
        </div>
        {{ end }}
      </div>
    </nav>

    <!-- Main Stage -->
    <div class="stage">

      <!-- ── Question Pages ─────────────────────────────────────────── -->
      {{ range .Questions }}
      <div class="q-page" id="page-{{ .DOMID }}" data-idx="{{ .Index }}">

        <!-- Meta row -->
        <div class="q-meta">
          <span class="q-type-pill">{{ .TypeLabel }}</span>
          {{ if .Title }}<span class="q-title-text">{{ .Title }}</span>{{ end }}
          {{ if .HasHint }}
          <button class="btn-hint-inline" onclick="toggleHint('{{ .DOMID }}')">💡 Hint</button>
          {{ end }}
        </div>

        <!-- Hint -->
        {{ if .HasHint }}
        <div class="hint-box" id="hint-{{ .DOMID }}">
          <div class="hint-label">Hint</div>
          {{ .Hint }}
        </div>
        {{ end }}

        <!-- Tags -->
        {{ if .Tags }}
        <div class="tag-row">{{ range .Tags }}<span class="tag">{{ . }}</span>{{ end }}</div>
        {{ end }}

        <!-- Prompt -->
        <div class="q-prompt">{{ html .PromptHTML }}</div>

        <!-- Answers area (scrollable) -->
        <div class="answers-area">

          <!-- Multiple Choice / True-False -->
          {{ if or (eq .Type "multiple-choice") (eq .Type "true-false") }}
          {{ $qid := .DOMID }}
          <div class="choice-list" id="choices-{{ $qid }}">
            {{ range $i, $c := .Choices }}
            <div class="choice-item"
                 id="choice-{{ $qid }}-{{ $i }}"
                 data-correct="{{ $c.Correct }}"
                 onclick="selectRadio('{{ $qid }}', {{ $i }})">
              <div class="choice-marker"><span class="choice-check">✓</span></div>
              <span class="choice-label">{{ $c.Text }}</span>
            </div>
            {{ end }}
          </div>
          {{ end }}

          <!-- Multi-Select -->
          {{ if eq .Type "multi-select" }}
          {{ $qid := .DOMID }}
          <div class="choice-list" id="choices-{{ $qid }}">
            {{ range $i, $c := .Choices }}
            <div class="choice-item"
                 id="choice-{{ $qid }}-{{ $i }}"
                 data-correct="{{ $c.Correct }}"
                 onclick="toggleCheckbox('{{ $qid }}', {{ $i }})">
              <div class="choice-marker checkbox"><span class="choice-check">✓</span></div>
              <span class="choice-label">{{ $c.Text }}</span>
            </div>
            {{ end }}
          </div>
          {{ end }}

          <!-- Multi-True-False -->
          {{ if eq .Type "multi-true-false" }}
          {{ $qid := .DOMID }}
          <div class="mtf-list" id="choices-{{ $qid }}">
            {{ range $i, $c := .Choices }}
            <div class="mtf-row" id="mtfrow-{{ $qid }}-{{ $i }}" data-tfcorrect="{{ $c.TFCorrect }}">
              <span class="mtf-label">{{ $c.Text }}</span>
              <div class="mtf-toggle-group">
                <button class="mtf-btn" id="mtf-{{ $qid }}-{{ $i }}-t" onclick="selectMTF('{{ $qid }}', {{ $i }}, true)">T</button>
                <button class="mtf-btn" id="mtf-{{ $qid }}-{{ $i }}-f" onclick="selectMTF('{{ $qid }}', {{ $i }}, false)">F</button>
              </div>
            </div>
            {{ end }}
          </div>
          {{ end }}

          <!-- Short Answer -->
          {{ if eq .Type "short-answer" }}
          <textarea class="short-answer-input"
                    id="answer-{{ .DOMID }}"
                    data-expected="{{ .AnswerText }}"
                    placeholder="Type your answer here…"
                    rows="3"></textarea>
          {{ end }}

          <!-- Ordering -->
          {{ if eq .Type "ordering" }}
          {{ $qid := .DOMID }}
          <ul class="ordering-list" id="ordering-{{ $qid }}">
            {{ range $i, $c := .Choices }}
            <li class="ordering-item"
                id="order-item-{{ $qid }}-{{ $i }}"
                draggable="true"
                data-correct-order="{{ $c.Order }}"
                ondragstart="dragStart(event, '{{ $qid }}')"
                ondragover="dragOver(event)"
                ondrop="drop(event, '{{ $qid }}')"
                ondragend="dragEnd(event, '{{ $qid }}')">
              <span class="drag-handle">⣿</span>
              <span class="ordering-rank">{{ add $i 1 }}</span>
              <span class="ordering-item-label">{{ $c.Text }}</span>
            </li>
            {{ end }}
          </ul>
          {{ end }}

          <!-- Feedback (inside answers-area so it scrolls with choices) -->
          <div class="feedback" id="feedback-{{ .DOMID }}">
            <div class="feedback-title" id="feedback-title-{{ .DOMID }}"></div>
            {{ if .HasExplain }}
            <div class="feedback-explain">{{ html .ExplainHTML }}</div>
            {{ end }}
          </div>

        </div><!-- /answers-area -->

        <!-- Action bar -->
        <div class="action-bar">
            <button class="btn-nav" id="prev-{{ .DOMID }}" onclick="goTo({{ .Index }} - 2)"
                  {{ if eq .Index 1 }}disabled{{ end }}>← Prev</button>
            <button class="btn-submit" id="submit-{{ .DOMID }}" onclick="submitQuestion('{{ .DOMID }}')">Check Answer</button>
          <div class="spacer"></div>
            <button class="btn-nav" id="next-{{ .DOMID }}" onclick="goTo({{ .Index }})"
                  {{ if eq .Index $.TotalCount }}disabled{{ end }}>Next →</button>
        </div>

      </div><!-- /q-page -->
      {{ end }}

      <!-- ── Summary Page ──────────────────────────────────────────── -->
      <div class="summary-page" id="page-summary">
        <div class="summary-icon" id="sum-icon">🎉</div>
        <div class="summary-title">Quiz Complete!</div>
        <div class="big-score" id="sum-pct">—%</div>
        <div class="summary-label" id="sum-label">Answer all questions to see your score.</div>
        <div class="summary-mode-note {{ if .ServerMode }}tracked{{ else }}static{{ end }}">
          {{ if .ServerMode }}Tracked mode is on. Finishing this quiz saves the session for later review in sfq history and sfq results.{{ else }}Static mode is on. This page shows your results now, but sfq does not save them for later review.{{ end }}
        </div>
        <div class="summary-stats">
          <div class="stat"><div class="stat-val c" id="sum-correct">0</div><div class="stat-lbl">Correct</div></div>
          <div class="stat"><div class="stat-val w" id="sum-wrong">0</div><div class="stat-lbl">Incorrect</div></div>
          <div class="stat"><div class="stat-val sk" id="sum-skip">{{ .TotalCount }}</div><div class="stat-lbl">Remaining</div></div>
        </div>
        <button class="btn-restart" onclick="goTo(0)">← Back to first question</button>
        <button class="btn-restart" id="btn-finish-session" style="display:none; background:var(--accent); color:#fff; border-color:var(--accent); margin-left:0.5rem;">✓ Finish Session</button>
      </div>

    </div><!-- /stage -->
  </div><!-- /body-layout -->

<script>
(() => {
  'use strict';

  const TOTAL = {{ .TotalCount }};
  const ids   = [{{ range .Questions }}'{{ .DOMID }}',{{ end }}];

  // ── Server Mode ───────────────────────────────────────────────────
  const SERVER_MODE = {{ if .ServerMode }}true{{ else }}false{{ end }};

  // Per-question metadata for server-mode POSTs
  const Q_META = {
    {{ range .Questions }}'{{ .DOMID }}': { id: {{ printf "%q" .ID }}, title: {{ printf "%q" .Title }}, tags: [{{ range .Tags }}{{ printf "%q" . }},{{ end }}], type: '{{ .Type }}' },
    {{ end }}
  };

  // ── State ─────────────────────────────────────────────────────────
  let current = 0;  // 0-based index into ids, TOTAL = summary
  const st = {};
  const qStartTimes = {}; // question open time for time_spent_s calculation
  ids.forEach(id => { st[id] = { answered: false, correct: false }; });

  // ── Navigation ────────────────────────────────────────────────────
  function goTo(idx) {
    if (idx < 0) idx = 0;
    if (idx > TOTAL) idx = TOTAL;
    current = idx;

    // Hide all pages
    ids.forEach(id => {
      const p = document.getElementById('page-' + id);
      if (p) p.classList.remove('active');
    });
    const sumPage = document.getElementById('page-summary');

    if (idx === TOTAL) {
      if (sumPage) sumPage.classList.add('active');
      document.getElementById('nav-summary').classList.add('active');
    } else {
      if (sumPage) sumPage.classList.remove('active');
      document.getElementById('nav-summary').classList.remove('active');
      const id = ids[idx];
      const page = document.getElementById('page-' + id);
      if (page) page.classList.add('active');
    }

    updateSidebarActive();
    updateTopbar();
    updateSummary();

    // Track when a question page is opened (for time_spent_s)
    if (SERVER_MODE && idx < TOTAL) {
      qStartTimes[ids[idx]] = Date.now();
    }

    // Scroll active sidebar item into view
    if (idx < TOTAL) {
      const navEl = document.getElementById('nav-' + ids[idx]);
      if (navEl) navEl.scrollIntoView({ block: 'nearest' });
    }
  }

  window.goTo = goTo;
  window.goToSummary = () => goTo(TOTAL);

  function updateTopbar() {
    const curEl = document.getElementById('cur-q');
    if (curEl) curEl.textContent = current < TOTAL ? current + 1 : '—';

    let answered = 0, correct = 0, wrong = 0;
    ids.forEach(id => {
      if (st[id].answered) { answered++; st[id].correct ? correct++ : wrong++; }
    });
    document.getElementById('score-correct').textContent = correct;
    document.getElementById('score-wrong').textContent   = wrong;
    document.getElementById('progress-fill').style.width = (answered / TOTAL * 100) + '%';
  }

  function updateSidebarActive() {
    document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
    if (current < TOTAL) {
      const el = document.getElementById('nav-' + ids[current]);
      if (el) el.classList.add('active');
    } else {
      document.getElementById('nav-summary').classList.add('active');
    }
  }

  function updateSidebarItem(id) {
    const el = document.getElementById('nav-' + id);
    const badge = document.getElementById('nav-badge-' + id);
    if (!el) return;
    el.classList.remove('correct', 'wrong');
    if (st[id].answered) {
      el.classList.add(st[id].correct ? 'correct' : 'wrong');
      if (badge) badge.textContent = st[id].correct ? '✓' : '✗';
    }
  }

  function updateSummary() {
    let answered = 0, correct = 0, wrong = 0;
    ids.forEach(id => {
      if (st[id].answered) { answered++; st[id].correct ? correct++ : wrong++; }
    });
    document.getElementById('sum-correct').textContent = correct;
    document.getElementById('sum-wrong').textContent   = wrong;
    document.getElementById('sum-skip').textContent    = TOTAL - answered;
    if (answered === TOTAL) {
      const pct = Math.round(correct / TOTAL * 100);
      document.getElementById('sum-pct').textContent = pct + '%';
      const label = pct >= 90 ? '🏆 Excellent!' : pct >= 70 ? '👍 Good job!' : pct >= 50 ? '📖 Keep studying!' : '💪 You\'ve got this!';
      document.getElementById('sum-label').textContent = label;
      document.getElementById('sum-icon').textContent  = pct >= 70 ? '🎉' : '📚';
    } else {
      document.getElementById('sum-pct').textContent  = '—%';
      document.getElementById('sum-label').textContent = answered + ' of ' + TOTAL + ' answered.';
    }
  }

  // ── Hint ──────────────────────────────────────────────────────────
  window.toggleHint = function(id) {
    const b = document.getElementById('hint-' + id);
    if (b) b.classList.toggle('visible');
  };

  // ── Multiple-choice (radio) ────────────────────────────────────────
  window.selectRadio = function(qid, idx) {
    if (st[qid].answered) return;
    document.querySelectorAll('#choices-' + qid + ' .choice-item').forEach((el, i) => {
      el.classList.toggle('selected', i === idx);
      el.dataset.userSelected = i === idx ? '1' : '';
    });
  };

  // ── Multi-select (checkbox) ────────────────────────────────────────
  window.toggleCheckbox = function(qid, idx) {
    if (st[qid].answered) return;
    const el = document.getElementById('choice-' + qid + '-' + idx);
    if (!el) return;
    const on = el.classList.toggle('selected');
    el.dataset.userSelected = on ? '1' : '';
  };

  // ── Multi-True-False ───────────────────────────────────────────────
  window.selectMTF = function(qid, idx, isTrue) {
    const row = document.getElementById('mtfrow-' + qid + '-' + idx);
    if (row && row.classList.contains('disabled')) return;
    const t = document.getElementById('mtf-' + qid + '-' + idx + '-t');
    const f = document.getElementById('mtf-' + qid + '-' + idx + '-f');
    if (!t || !f) return;
    t.classList.remove('selected-t'); delete t.dataset.selected;
    f.classList.remove('selected-f'); delete f.dataset.selected;
    if (isTrue) { t.classList.add('selected-t'); t.dataset.selected = 'true'; }
    else         { f.classList.add('selected-f'); f.dataset.selected = 'false'; }
  };

  // ── Drag-and-drop (ordering) ───────────────────────────────────────
  let dragSrc = null;
  window.dragStart = function(e, qid) {
    dragSrc = e.currentTarget;
    e.dataTransfer.effectAllowed = 'move';
    setTimeout(() => { if (dragSrc) dragSrc.classList.add('dragging'); }, 0);
  };
  window.dragOver = function(e) {
    e.preventDefault(); e.dataTransfer.dropEffect = 'move';
    document.querySelectorAll('.ordering-item').forEach(el => el.classList.remove('drag-over'));
    e.currentTarget.classList.add('drag-over');
  };
  window.drop = function(e, qid) {
    e.preventDefault();
    if (!dragSrc || dragSrc === e.currentTarget) return;
    const dst = e.currentTarget;
    if (dst.compareDocumentPosition(dragSrc) & Node.DOCUMENT_POSITION_FOLLOWING) {
      dst.before(dragSrc);
    } else {
      dst.after(dragSrc);
    }
    refreshOrderRanks(qid);
  };
  window.dragEnd = function(e, qid) {
    document.querySelectorAll('.ordering-item').forEach(el => el.classList.remove('dragging', 'drag-over'));
    dragSrc = null;
  };
  function refreshOrderRanks(qid) {
    const list = document.getElementById('ordering-' + qid);
    if (!list) return;
    list.querySelectorAll('.ordering-rank').forEach((el, i) => { el.textContent = i + 1; });
  }

  function pickText(el, selector) {
    const node = el.querySelector(selector);
    return node ? node.textContent.trim() : '';
  }

  function clearChoiceStateBadges(qid) {
    document.querySelectorAll('#choices-' + qid + ' .choice-state').forEach(el => el.remove());
    document.querySelectorAll('#ordering-' + qid + ' .ordering-state').forEach(el => el.remove());
    document.querySelectorAll('#choices-' + qid + ' .mtf-state').forEach(el => el.remove());
  }

  function addStateBadge(item, text, cls) {
    const b = document.createElement('span');
    b.className = 'choice-state ' + cls;
    b.textContent = text;
    item.appendChild(b);
  }

  function addOrderingState(item, text, cls) {
    const b = document.createElement('span');
    b.className = 'ordering-state ' + cls;
    b.textContent = text;
    item.appendChild(b);
  }

  function addMTFState(row, html) {
    const s = document.createElement('div');
    s.className = 'mtf-state';
    s.innerHTML = html;
    row.appendChild(s);
  }

  function renderAnswerSummary(qid) {
    const fb = document.getElementById('feedback-' + qid);
    if (!fb) return;

    const existing = document.getElementById('answer-summary-' + qid);
    if (existing) existing.remove();

    const summary = document.createElement('div');
    summary.className = 'answer-summary';
    summary.id = 'answer-summary-' + qid;

    function row(label, values, variant) {
      const rowEl = document.createElement('div');
      rowEl.className = 'answer-summary-row';
      const lab = document.createElement('div');
      lab.className = 'answer-summary-label';
      lab.textContent = label;
      const val = document.createElement('div');
      val.className = 'answer-summary-value';
      (values && values.length ? values : ['(none)']).forEach(v => {
        const chip = document.createElement('span');
        chip.className = 'answer-chip' + (variant ? (' ' + variant) : '');
        chip.textContent = v;
        val.appendChild(chip);
      });
      rowEl.appendChild(lab);
      rowEl.appendChild(val);
      summary.appendChild(rowEl);
    }

    const choicesEl = document.getElementById('choices-' + qid);
    const orderEl = document.getElementById('ordering-' + qid);
    const answerEl = document.getElementById('answer-' + qid);

    if (choicesEl) {
      const items = [...choicesEl.children];
      const isMtf = items.length > 0 && items[0].classList.contains('mtf-row');
      if (isMtf) {
        const user = [];
        const corr = [];
        items.forEach((rowEl, i) => {
          const label = pickText(rowEl, '.mtf-label');
          const tb = document.getElementById('mtf-' + qid + '-' + i + '-t');
          const fbBtn = document.getElementById('mtf-' + qid + '-' + i + '-f');
          const userVal = tb && tb.dataset.selected === 'true' ? 'True' : fbBtn && fbBtn.dataset.selected === 'false' ? 'False' : 'No answer';
          const corVal = rowEl.dataset.tfcorrect === 'true' ? 'True' : 'False';
          user.push(label + ': ' + userVal);
          corr.push(label + ': ' + corVal);
        });
        row('Your Answers', user, 'wrong');
        row('Correct Answers', corr, 'correct');
      } else {
        const user = [];
        const corr = [];
        items.forEach(item => {
          const txt = pickText(item, '.choice-label');
          if (item.dataset.userSelected === '1') user.push(txt);
          if (item.dataset.correct === 'true') corr.push(txt);
        });
        row('Your Answers', user, user.length ? 'wrong' : '');
        row('Correct Answers', corr, 'correct');
      }
    } else if (orderEl) {
      const curItems = [...orderEl.querySelectorAll('.ordering-item')];
      const user = curItems.map(el => pickText(el, '.ordering-item-label'));
      const corr = [...curItems]
        .sort((a, b) => parseInt(a.dataset.correctOrder, 10) - parseInt(b.dataset.correctOrder, 10))
        .map(el => pickText(el, '.ordering-item-label'));
      row('Your Order', user, 'wrong');
      row('Correct Order', corr, 'correct');
    } else if (answerEl) {
      const user = answerEl.value.trim();
      const expected = answerEl.dataset.expected ? answerEl.dataset.expected.trim() : '';
      row('Your Answer', user ? [user] : ['(blank)'], 'wrong');
      row('Correct Answer', expected ? [expected] : ['(any non-empty answer accepted)'], 'correct');
    }

    fb.appendChild(summary);
  }

  // ── Evaluate ──────────────────────────────────────────────────────
  function evaluate(qid) {
    const card = document.getElementById('page-' + qid);
    const type = card ? card.closest('.q-page').dataset.type || card.dataset.type : '';
    const pageEl = document.getElementById('page-' + qid);
    const t = pageEl ? pageEl.querySelector('[data-type-val]') : null;
    // get type from question ids data attribute fallback
    const qtype = pageEl ? pageEl.getAttribute('data-qtype') : '';

    // Use the type stored on the answer containers
    const choicesEl = document.getElementById('choices-' + qid);
    const orderEl   = document.getElementById('ordering-' + qid);
    const answerEl  = document.getElementById('answer-' + qid);

    if (choicesEl) {
      const items = [...choicesEl.children];
      // detect type by marker shape
      const isCheckbox = items.length > 0 && items[0].querySelector('.checkbox');
      const isMtf = items.length > 0 && items[0].classList.contains('mtf-row');

      if (isMtf) {
        // multi-true-false
        let anySelected = false, allOk = true;
        items.forEach((row, i) => {
          const tb = document.getElementById('mtf-' + qid + '-' + i + '-t');
          const fb = document.getElementById('mtf-' + qid + '-' + i + '-f');
          const userT = tb && tb.dataset.selected === 'true';
          const userF = fb && fb.dataset.selected === 'false';
          if (userT || userF) anySelected = true;
          const exp = row.dataset.tfcorrect;
          if (exp === 'true'  && !userT) allOk = false;
          if (exp === 'false' && !userF) allOk = false;
        });
        if (!anySelected) return null;
        return { isCorrect: allOk };
      }

      if (isCheckbox) {
        // multi-select
        let anySelected = false, allOk = true;
        items.forEach(el => {
          const sel = el.dataset.userSelected === '1';
          const cor = el.dataset.correct === 'true';
          if (sel) anySelected = true;
          if (sel !== cor) allOk = false;
        });
        if (!anySelected) return null;
        return { isCorrect: allOk };
      }

      // radio (multiple-choice / true-false)
      let chosen = null;
      items.forEach(el => { if (el.dataset.userSelected === '1') chosen = el; });
      if (!chosen) return null;
      return { isCorrect: chosen.dataset.correct === 'true' };
    }

    if (orderEl) {
      const items = [...orderEl.querySelectorAll('.ordering-item')];
      const ok = items.every((el, i) => parseInt(el.dataset.correctOrder, 10) === i + 1);
      return { isCorrect: ok };
    }

    if (answerEl) {
      const val = answerEl.value.trim();
      if (!val) return null;
      const exp = answerEl.dataset.expected ? answerEl.dataset.expected.trim().toLowerCase() : null;
      return { isCorrect: exp === null || val.toLowerCase() === exp };
    }

    return null;
  }

  // ── Submit ────────────────────────────────────────────────────────
  window.submitQuestion = function(qid) {
    if (st[qid].answered) {
      // Already answered — just advance
      goTo(current + 1);
      return;
    }

    const result = evaluate(qid);
    if (result === null) {
      // Flash border
      const page = document.getElementById('page-' + qid);
      if (page) {
        page.style.outline = '2px solid var(--wrong)';
        setTimeout(() => { page.style.outline = ''; }, 700);
      }
      return;
    }

    const { isCorrect } = result;
    st[qid] = { answered: true, correct: isCorrect };

    // Disable submit / change label
    const submitBtn = document.getElementById('submit-' + qid);
    if (submitBtn) { submitBtn.textContent = 'Next →'; submitBtn.disabled = false; }

    // Reveal choices
    const choicesEl = document.getElementById('choices-' + qid);
    const orderEl   = document.getElementById('ordering-' + qid);
    const answerEl  = document.getElementById('answer-' + qid);

    if (choicesEl) {
      const items = [...choicesEl.children];
      const isCheckbox = items.length > 0 && items[0].querySelector('.checkbox');
      const isMtf = items.length > 0 && items[0].classList.contains('mtf-row');

      clearChoiceStateBadges(qid);

      if (isMtf) {
        items.forEach((row, i) => {
          row.classList.add('disabled');
          const tb = document.getElementById('mtf-' + qid + '-' + i + '-t');
          const fb = document.getElementById('mtf-' + qid + '-' + i + '-f');
          const exp = row.dataset.tfcorrect;
          const userT = tb && tb.dataset.selected === 'true';
          const userF = fb && fb.dataset.selected === 'false';

          if (tb) tb.classList.remove('correct-reveal', 'wrong-reveal', 'user-picked');
          if (fb) fb.classList.remove('correct-reveal', 'wrong-reveal', 'user-picked');

          if (userT && tb) tb.classList.add('user-picked');
          if (userF && fb) fb.classList.add('user-picked');

          if (exp === 'true') {
            if (tb) tb.classList.add('correct-reveal');
            if (userF && fb) fb.classList.add('wrong-reveal');
          } else {
            if (fb) fb.classList.add('correct-reveal');
            if (userT && tb) tb.classList.add('wrong-reveal');
          }

          const userVal = userT ? 'True' : userF ? 'False' : 'No answer';
          const corVal = exp === 'true' ? 'True' : 'False';
          if (userVal === corVal) {
            addMTFState(row, 'You answered <span class="good">' + userVal + '</span>. Correct answer is <span class="good">' + corVal + '</span>.');
          } else {
            addMTFState(row, 'You answered <span class="bad">' + userVal + '</span>. Correct answer is <span class="good">' + corVal + '</span>.');
          }
        });
      } else {
        items.forEach(el => {
          el.classList.add('disabled');
          const selected = el.dataset.userSelected === '1';
          const correct = el.dataset.correct === 'true';

          el.classList.remove('user-picked', 'missed-correct');
          if (selected) el.classList.add('user-picked');

          if (correct && selected) {
            el.classList.add('correct-reveal');
            addStateBadge(el, 'Your Answer + Correct', 'correct');
          } else if (correct) {
            el.classList.add('correct-reveal', 'missed-correct');
            addStateBadge(el, 'Correct Answer', 'correct');
          } else if (selected) {
            el.classList.add('wrong-reveal');
            addStateBadge(el, 'Your Answer', 'wrong');
          }
        });
      }
    }
    if (orderEl) {
      clearChoiceStateBadges(qid);
      [...orderEl.querySelectorAll('.ordering-item')].forEach((el, i) => {
        el.classList.add('disabled');
        const expected = parseInt(el.dataset.correctOrder, 10);
        const ok = expected === i + 1;
        el.classList.add(ok ? 'correct-reveal' : 'wrong-reveal');
        addOrderingState(el, ok ? 'Correct Position' : ('Should be #' + expected), ok ? 'correct' : 'wrong');
      });
    }
    if (answerEl) answerEl.disabled = true;

    // Feedback
    const fb = document.getElementById('feedback-' + qid);
    const ft = document.getElementById('feedback-title-' + qid);
    if (fb && ft) {
      fb.classList.add('visible', isCorrect ? 'correct' : 'wrong');
      ft.textContent = isCorrect ? '✅ Correct!' : '❌ Incorrect';
    }

    renderAnswerSummary(qid);

    updateSidebarItem(qid);
    updateTopbar();
    updateSummary();

    // ── POST answer to server (server mode only) ─────────────────────
    if (SERVER_MODE) {
      const elapsed = qStartTimes[qid] ? Math.round((Date.now() - qStartTimes[qid]) / 1000) : 0;
      const meta = Q_META[qid] || {};
      fetch('/answer', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          question_id:    meta.id || qid,
          question_title: meta.title || meta.id || qid,
          tags:           meta.tags  || [],
          type:           meta.type  || '',
          correct:        isCorrect,
          time_spent_s:   elapsed,
        }),
      }).catch(() => {}); // non-fatal
    }
  };

  // ── Keyboard navigation ────────────────────────────────────────────
  document.addEventListener('keydown', e => {
    if (e.target.tagName === 'TEXTAREA' || e.target.tagName === 'INPUT') return;
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown')  goTo(current + 1);
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')    goTo(current - 1);
    if (e.key === 'Enter' && current < TOTAL) {
      const id = ids[current];
      submitQuestion(id);
    }
  });

  // ── Init ──────────────────────────────────────────────────────────
  goTo(0);

  // ── Server-mode plumbing ──────────────────────────────────────────
  if (SERVER_MODE) {
    // Heartbeat every 5 s so the server knows the window is still open
    setInterval(() => { fetch('/heartbeat', { method: 'POST' }).catch(() => {}); }, 5000);

    const finishSession = () => {
      let correct = 0, incorrect = 0;
      ids.forEach(id => {
        if (st[id].answered) { st[id].correct ? correct++ : incorrect++; }
      });
      const skipped = TOTAL - correct - incorrect;
      fetch('/finish', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ correct, incorrect, skipped }),
      }).catch(() => {}).finally(() => window.close());
    };

    // Sidebar finish button exists only in server mode.
    window.sidebarFinish = finishSession;

    // Wire up the Finish Session button (revealed in server mode)
    const finishBtn = document.getElementById('btn-finish-session');
    if (finishBtn) {
      finishBtn.style.display = 'inline-flex';
      finishBtn.addEventListener('click', finishSession);
    }
  }
})();
</script>
</body>
</html>
